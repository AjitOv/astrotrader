# Local development uses 127.0.0.1:8000 by default.
# In production (Vercel) set this to your Render service URL.
ASTROTRADE_API_URL=http://127.0.0.1:8000

# Optional: timeout for the engine call in ms. Default 60000.
# Increase to ~90000 if Render free tier cold starts are timing out.
# ASTROTRADE_API_TIMEOUT_MS=90000
